name: Build APK
on:
  push:
    branches: [main]
  workflow_dispatch:
jobs:
  build:
    runs-on: ubuntu-22.04
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-verson: "3.10"
      - uses: actions/setup-java@v4
        with:
          distribution: "temurin"
          java-version: "11"
      - name: Install dep
        run: |
          sudo apt update
          sudo apt install -y git zip unzip autoconf libtool cmake
          echo "$HOME/.local/bin" >> $GITHUB_PATH
      - name: Install Buildozer
        run: |
          python -m pip install --upgrade pip
          python -m pip install buildozer==1.4.0 Cython==0.29.36
      - name: Build
        run: buildozer android debug
      - name: Simpan APK
        uses: actions/upload-artifact@v4
        with:
          name: apk-hasil
          path: bin/*.apk
